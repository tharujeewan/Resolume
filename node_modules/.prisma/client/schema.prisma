datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum RoleName {
  SUPER_ADMIN
  ORGANIZER
  GUEST
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
  DELETED
}

enum EventStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Role {
  id    Int      @id @default(autoincrement())
  name  RoleName @unique
  users User[]

  @@map("roles")
}

model User {
  id                   String         @id @default(uuid()) @db.Uuid
  email                String         @unique
  passwordHash         String
  firstName            String?
  lastName             String?
  roleId               Int
  role                 Role           @relation(fields: [roleId], references: [id])
  isVerified           Boolean        @default(false)
  verificationToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  events               Event[]
  refreshTokens        RefreshToken[]
  activityLogs         ActivityLog[]

  @@map("users")
}

model Event {
  id             String      @id @default(uuid()) @db.Uuid
  name           String
  slug           String      @unique
  description    String?
  date           DateTime
  venue          String?
  startTime      String?
  endTime        String?
  status         EventStatus @default(DRAFT)
  theme          String      @default("dark")
  background     String? // File path or color code
  logo           String? // File path or URL
  maxUploadLimit Int         @default(200)
  userId         String      @db.Uuid
  organizer      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos         Photo[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("events")
}

model Photo {
  id                String      @id @default(uuid()) @db.Uuid
  eventId           String      @db.Uuid
  event             Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  originalName      String
  filename          String
  thumbnailFilename String?
  optimizedFilename String?
  status            PhotoStatus @default(PENDING)
  size              Int // File size in bytes
  width             Int?
  height            Int?
  mimeType          String
  uploadedBy        String? // IP Address or guest device identifier
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("photos")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Setting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
