# Environment
NODE_ENV=development
PORT=5000

# Database (PostgreSQL container matching Docker Compose setup)
DATABASE_URL="postgresql://postgres:0772@localhost:5432/eventwall?schema=public"

# Authentication Secrets
JWT_SECRET=eventwall_jwt_secret_key_change_me_in_prod_12345
JWT_REFRESH_SECRET=eventwall_jwt_refresh_secret_key_change_me_in_prod_54321
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Uploads Configuration
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=10485760 # 10MB in bytes

# Domain settings
PUBLIC_DOMAIN="http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"
AUTO_APPROVE_PHOTOS=true

# Mock SMTP Configuration (Leave empty to log emails to console)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@eventwall.com"
